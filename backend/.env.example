NODE_ENV=development
PORT=3000
DATABASE_URL=postgresql://postgres:PASSWORD@localhost:5432/crm?schema=public
REDIS_URL=redis://:PASSWORD@localhost:6379/2
JWT_SECRET=change-me-super-secret-jwt-key-minimum-32-characters
JWT_REFRESH_SECRET=change-me-refresh-secret-key-minimum-32-characters
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d
EVOLUTION_API_URL=http://localhost:8080
EVOLUTION_API_KEY=CHANGE_ME_API_KEY
WEBHOOK_SECRET=change-me-webhook-secret
# URL that the Evolution API container uses to call back into your backend.
# Local dev (Docker Desktop on Windows/Mac): http://host.docker.internal:3000
# Inside docker-compose (backend also containerised): http://crm-backend:3000
BACKEND_URL=http://host.docker.internal:3000
FRONTEND_URL=http://localhost:5173
LOG_LEVEL=info
