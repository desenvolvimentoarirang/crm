# ─── Database ────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://postgres:PASSWORD@localhost:5432/crm?schema=public

# ─── Redis ───────────────────────────────────────────────────────────────────
REDIS_URL=redis://:PASSWORD@localhost:6379/2

# ─── Auth ────────────────────────────────────────────────────────────────────
JWT_SECRET=change-me-super-secret-jwt-key-minimum-32-characters
JWT_REFRESH_SECRET=change-me-super-secret-refresh-key-minimum-32-characters
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# ─── Evolution API ───────────────────────────────────────────────────────────
EVOLUTION_API_URL=http://localhost:8080
EVOLUTION_API_KEY=CHANGE_ME_API_KEY
WEBHOOK_SECRET=change-me-webhook-hmac-secret

# ─── Server ──────────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=3000
FRONTEND_URL=http://localhost:5173
LOG_LEVEL=info
